# Required: the Anthropic API key used for the chat loop.
ANTHROPIC_API_KEY=

# --- Oracle EPM mode (spawned MCP servers inherit these) ---
# Leave unset / EPM_MODE=mock for a credential-free demo off the fixtures.
# Uncomment and fill the block below to talk to a live on-prem server.
EPM_MODE=mock
# EPM_DEPLOYMENT=onprem
# EPM_SERVER_HOSTNAME=10.10.10.20
# EPM_SERVER_PORT=19000
# EPM_USE_HTTPS=false
# EPM_VERIFY_SSL_CERT=true
# EPM_USERNAME=admin
# EPM_PASSWORD=changeme
# EPM_API_VERSION=11.1.2.4
# EPM_ESSBASE_BASE_PATH=/essbase/rest/v1
