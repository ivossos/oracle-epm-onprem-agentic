# Oracle EPM environment (leave blank / MOCK for demos & evals)
# EPM_MODE controls the client: "mock" (default) or "live"
EPM_MODE=mock

# --- Live mode only (do NOT commit real values) ---
# Base URL of the EPM Cloud instance, e.g. https://<pod>.epm.<dc>.oraclecloud.com
EPM_BASE_URL=
# Identity domain (Classic) — omit for OCI/IDCS if not required
EPM_IDENTITY_DOMAIN=
# Basic Auth (non-MFA environments only). Prefer OAuth for production.
EPM_USERNAME=
EPM_PASSWORD=
# REST API version segment, e.g. v3
EPM_API_VERSION=v3

# --- OAuth 2.0 (recommended for MFA/production) ---
EPM_OAUTH_TOKEN_URL=
EPM_OAUTH_CLIENT_ID=
EPM_OAUTH_CLIENT_SECRET=
EPM_OAUTH_SCOPE=
