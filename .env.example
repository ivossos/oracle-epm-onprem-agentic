# Oracle EPM environment (leave blank / MOCK for demos & evals)
# EPM_MODE controls the client: "mock" (default) or "live"
EPM_MODE=mock

# EPM_DEPLOYMENT selects the target environment: "cloud" (default) or "onprem"
# Determines which API endpoints and auth methods are used.
EPM_DEPLOYMENT=cloud

# --- Cloud deployment (EPM_DEPLOYMENT=cloud) ---
# Base URL of the EPM Cloud instance, e.g. https://<pod>.epm.<dc>.oraclecloud.com
EPM_BASE_URL=
# Identity domain (Classic) — omit for OCI/IDCS if not required
EPM_IDENTITY_DOMAIN=

# --- On-premises deployment (EPM_DEPLOYMENT=onprem) ---
# On-prem Oracle EPM 11.1.2.4 uses Basic Auth only.
# Example: http://epm-server.internal:8080 or https://epm.mycompany.com
EPM_SERVER_HOSTNAME=
EPM_SERVER_PORT=8080
EPM_USE_HTTPS=false
# Set to false to accept self-signed certificates (dev/test only!)
EPM_VERIFY_SSL_CERT=true

# --- Credentials (both cloud and on-prem) ---
# Basic Auth (non-MFA environments only). Prefer OAuth for cloud production.
EPM_USERNAME=
EPM_PASSWORD=
# REST API version segment, e.g. v3 (for both cloud and on-prem 11.1.2.4+)
EPM_API_VERSION=v3

# --- OAuth 2.0 (cloud only; recommended for MFA/production) ---
# On-prem deployments ignore OAuth config and always use Basic Auth.
EPM_OAUTH_TOKEN_URL=
EPM_OAUTH_CLIENT_ID=
EPM_OAUTH_CLIENT_SECRET=
EPM_OAUTH_SCOPE=
